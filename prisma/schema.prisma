// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// see https://github.com/prisma/prisma/issues/27486 why driverAdapters can't be used
// TLDR: vite removes it during bundling it or something like that
generator client {
  provider        = "prisma-client"
  output          = "./client"
  previewFeatures = ["fullTextSearchPostgres", "relationJoins"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

/**
 * generator arktype {
 * provider    = "yarn prismark"
 * output      = "./validate"
 * fileName    = "schema.ts"
 * nullish     = true
 * }
 */

datasource db {
  provider = "postgresql"
}

// ─── New models for Phase 1 ───
// These models are added to the schema and reference existing models from prisma/models/

enum AchieveMode {
  Gameplay
  Sync
}

enum ShowcaseType {
  FavoriteGame
  Achievement
  GameStats
  Custom
}

enum LeaderboardType {
  Playtime
  AchievementCount
  Speedrun
  Score
}

enum SortOrder {
  Asc
  Desc
}

enum VoteType {
  Up
  Down
}

model Leaderboard {
  id        String           @id @default(uuid())
  gameId    String
  game      Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name      String
  type      LeaderboardType
  sortOrder SortOrder        @default(Desc)
  createdAt DateTime         @default(now())

  entries   LeaderboardEntry[]

  @@unique([gameId, name])
  @@index([gameId])
}

model LeaderboardEntry {
  id           String   @id @default(uuid())
  leaderboardId String
  leaderboard  Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Float
  submittedAt  DateTime @default(now())
  data         Json?
  rank         Int?

  @@unique([leaderboardId, userId])
  @@index([leaderboardId])
  @@index([userId])
  @@index([score])
}

model ProfileShowcase {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       ShowcaseType
  gameId     String?
  game       Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  itemId     String?
  title      String   @default("")
  data       Json?
  sortOrder  Int      @default(0)

  @@index([userId])
  @@index([sortOrder])
}

model RequestVote {
  requestId String
  request   GameRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote      VoteType
  createdAt DateTime    @default(now())
  @@id([requestId, userId])
  @@index([requestId])
  @@index([userId])
}

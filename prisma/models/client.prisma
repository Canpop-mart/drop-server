enum ClientCapabilities {
  PeerAPI       @map("peerAPI") // other clients can use the HTTP API to P2P with this client
  UserStatus    @map("userStatus") // this client can report this user's status (playing, online, etc etc)
  TrackPlaytime @map("trackPlaytime") // ability to track user playtime
}

// References a device
model Client {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  capabilities ClientCapabilities[]

  name          String
  platform      Platform
  lastConnected DateTime

  tokens APIToken[]
  streamingSessions StreamingSession[]
  requestedStreams  StreamingSession[] @relation("StreamingSessionRequester")
  installedGames    ClientInstalledGame[]
  compatibilityResults GameCompatibilityResult[]
}

/// Tracks which games are installed on which client devices.
/// Synced by each client on startup and after installs/uninstalls.
model ClientInstalledGame {
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  syncedAt DateTime @default(now()) @db.Timestamptz(6)

  @@id([clientId, gameId])
  @@index([gameId])
}

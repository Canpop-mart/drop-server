model User {
    id       String  @id @default(uuid())
    username String  @unique
    admin    Boolean @default(false)
    enabled  Boolean @default(true)

    email                  String
    displayName            String
    profilePictureObjectId String // Object
    bannerObjectId         String  @default("")
    bio                    String  @default("")
    profileTheme           String  @default("default")

    favoriteGames FavoriteGame[]

    authMecs LinkedAuthMec[]
    mfas     LinkedMFAMec[]

    clients       Client[]
    notifications Notification[]
    collections   Collection[]
    articles      Article[]

    tokens   APIToken[]
    sessions Session[]

    screenshots Screenshot[]
    playtime      Playtime[]
    playSessions  PlaySession[]

    gameRequests         GameRequest[] @relation(name: "requestsCreated")
    reviewedGameRequests GameRequest[] @relation(name: "requestsReviewed")

    achievements     UserAchievement[]
    showcases        ProfileShowcase[]
    leaderboardEntries LeaderboardEntry[]
    requestVotes     RequestVote[]
    externalAccounts UserExternalAccount[]

    bugReports         BugReport[] @relation(name: "bugReportsCreated")
    assignedBugReports BugReport[] @relation(name: "bugReportsAssigned")

    cloudSaves CloudSave[]
    streamingSessions StreamingSession[]
}

model FavoriteGame {
    id String @id @default(uuid())

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    gameId String
    game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

    position Int @default(0)

    createdAt DateTime @default(now())

    @@unique([userId, gameId])
    @@index([userId])
}

model Notification {
    id String @id @default(uuid())

    nonce String?

    userId String
    user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    acls   String[]

    created     DateTime @default(now())
    title       String
    description String
    actions     String[]

    read Boolean @default(false)

    @@unique([userId, nonce])
}

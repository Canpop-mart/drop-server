enum ExternalAccountProvider {
    Steam
    RetroAchievements
    Goldberg
}

model GameExternalLink {
    id             String                  @id @default(uuid())
    gameId         String
    game           Game                    @relation(fields: [gameId], references: [id], onDelete: Cascade)
    provider       ExternalAccountProvider
    externalGameId String
    /// RA console ID (e.g. 21 = PS2, 2 = N64). Populated when linking.
    consoleId      Int?

    @@unique([gameId, provider])
    @@index([gameId])
}

/// Cached RetroAchievements hash entries for a game.
/// Periodically refreshed from the RA API so the client can verify
/// ROM integrity without hitting the RA API directly.
model GameExternalHash {
    id         String                  @id @default(uuid())
    gameId     String
    game       Game                    @relation(fields: [gameId], references: [id], onDelete: Cascade)
    provider   ExternalAccountProvider
    hash       String                  // MD5 hash of the recognised ROM
    label      String                  @default("") // e.g. "Psychonauts (USA) (v1.0)"
    patchUrl   String                  @default("") // URL to compatibility patch (if any)
    cachedAt   DateTime                @default(now())

    @@unique([gameId, provider, hash])
    @@index([gameId])
}

model Achievement {
    id            String                  @id @default(uuid())
    gameId        String
    game          Game                    @relation(fields: [gameId], references: [id], onDelete: Cascade)
    externalId    String
    provider      ExternalAccountProvider
    title         String
    description   String
    iconUrl       String                  @default("")
    iconLockedUrl String                  @default("")
    displayOrder  Int                     @default(0)

    unlocks UserAchievement[]

    @@unique([gameId, provider, externalId])
    @@index([gameId])
}

model UserAchievement {
    id            String      @id @default(uuid())
    userId        String
    user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    achievementId String
    achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
    unlockedAt    DateTime
    syncedAt      DateTime    @default(now())

    @@unique([userId, achievementId])
    @@index([userId])
    @@index([achievementId])
}

model UserExternalAccount {
    id         String                  @id @default(uuid())
    userId     String
    user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
    provider   ExternalAccountProvider
    externalId   String                  // RA username
    token        String                  @default("") // RA Web API key
    connectToken String                  @default("") // RA Connect token (for emulator auth)

    @@unique([userId, provider])
    @@index([provider, externalId])
}
